# Example configuration only.
# Never commit real secrets, API keys, merchant passwords, or production values.

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=zcash

# Server Configuration
APP_URL=http://localhost:5173
API_URL=http://localhost:8000/api
JWT_SECRET=replace_with_a_long_random_secret

# Payment Gateway Keys (Get from Easypaisa & JazzCash)
EASYPAISA_API_KEY=replace_with_easypaisa_api_key
EASYPAISA_MERCHANT_ID=replace_with_easypaisa_merchant_id
JAZZCASH_API_KEY=replace_with_jazzcash_api_key
JAZZCASH_MERCHANT_ID=replace_with_jazzcash_merchant_id

# Exchange Rate
USD_TO_PKR=278

# Admin Settings
ADMIN_EMAIL=admin@zcash.com
